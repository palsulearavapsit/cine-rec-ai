# CineRec AI Backend Settings
PROJECT_NAME="CineRec AI"
API_V1_STR="/api/v1"

# Supabase Configurations
# Obtain these from your Supabase Project Settings -> API
SUPABASE_URL="https://your-supabase-project-id.supabase.co"
SUPABASE_ANON_KEY="your-supabase-anon-key"
# The service role key is critical for the backend workers to fetch files and update tables bypassing user RLS
SUPABASE_SERVICE_ROLE_KEY="your-supabase-service-role-key"
# Used by FastAPI to decode Supabase Auth JWTs. 
# Obtain from Project Settings -> API -> JWT Settings -> JWT Secret
SUPABASE_JWT_SECRET="your-supabase-jwt-secret"

# Celery & Broker Config
# Use localhost for development, or the 'redis' host name inside docker-compose
REDIS_URL="redis://localhost:6379/0"
CELERY_BROKER_URL="redis://localhost:6379/0"
CELERY_RESULT_BACKEND="redis://localhost:6379/0"

# Local storage scratch path
SCRATCH_DIR="/tmp/cinerec_scratch"
